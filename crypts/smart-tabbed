#!/usr/bin/env bash

prog=$1
win=$(xdotool getactivewindow 2>/dev/null)

BLACKBOOK="http://localhost:3000"

if [ -n "$win" ] && xprop -id "$win" 2>/dev/null | grep -q '"tabbed"'; then

  if [ "$prog" = surf ]; then
    bash /home/cadenas/blackbook/launch.sh
    exec surf -e "$win" "$BLACKBOOK"
  else
    exec st -w "$win" -e "$prog"
  fi

else

  if [ "$prog" = surf ]; then
    bash /home/cadenas/blackbook/launch.sh
    exec tabbed -c surf -e
  else
    exec tabbed -c -r 2 st -w '' -e "$prog"
  fi

fi
